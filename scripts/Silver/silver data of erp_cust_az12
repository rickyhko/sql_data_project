SELECT
cid,
CASE WHEN cid LIKE 'NAS%' THEN substring(cid, 4, length(cid) )
	ELSE cid
    END cid,
bdate,
CASE WHEN bdate > CURDATE() THEN NULL -- we can do or ask much but this one is 100% incorrect
	ELSE bdate
	END bdate,
gen,
CASE
    WHEN UPPER(TRIM(REPLACE(gen, CHAR(13), ''))) IN ('F', 'FEMALE') THEN 'Female' -- I use replace because there is non printable character included in all gen
    WHEN UPPER(TRIM(REPLACE(gen, CHAR(13), ''))) IN ('M', 'MALE') THEN 'Male'
    ELSE 'Unknown'
END AS gen
FROM bronze.erp_cust_az12;

-- identify out of range date
-- ask for someone to correct it

SELECT bdate
FROM bronze.erp_cust_az12
WHERE bdate IS NULL
   OR bdate < '1924-01-01'
   OR bdate > CURDATE();
   
-- standarization

SELECT DISTINCT gen
FROM bronze.erp_cust_az12;

SELECT
    CONCAT('[', gen, ']') AS gender,
    COUNT(*) AS cnt
FROM bronze.erp_cust_az12
GROUP BY gen;

SELECT DISTINCT
    gen,
    HEX(gen)
FROM bronze.erp_cust_az12
WHERE gen IS NOT NULL
LIMIT 20;

